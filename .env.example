# ---------------------------------------------------------------------------
# Garmin Connect MCP Server — environment configuration
# Copy to .env and fill in your values.
# ---------------------------------------------------------------------------

# Transport: "http" (for Claude.ai remote connector) or "stdio" (Inspector/Desktop)
TRANSPORT=http

# HTTP transport settings (only used when TRANSPORT=http)
PORT=3000
HOST=0.0.0.0

# Public base URL of this server (used to build OAuth redirect URIs)
PUBLIC_BASE_URL=http://localhost:3000

# ---------------------------------------------------------------------------
# Garmin Connect Developer Program — OAuth 2.0 credentials
# Apply at https://developer.garmin.com/gc-developer-program/overview/
# ---------------------------------------------------------------------------
GARMIN_CLIENT_ID=
GARMIN_CLIENT_SECRET=

# Garmin OAuth 2.0 endpoints (override only if Garmin changes them)
GARMIN_AUTHORIZE_URL=https://connect.garmin.com/oauth2Confirm
GARMIN_TOKEN_URL=https://diauth.garmin.com/di-oauth2-service/oauth/token

# Garmin REST API base
GARMIN_API_BASE_URL=https://apis.garmin.com

# Space-separated OAuth scopes requested from Garmin
GARMIN_SCOPES=

# ---------------------------------------------------------------------------
# Token storage backend: "memory" (default) or "redis"
# ---------------------------------------------------------------------------
TOKEN_STORE=memory
REDIS_URL=redis://localhost:6379

# Optional: log level (debug | info | warn | error)
LOG_LEVEL=info
